{
    "compileOnSave": true,
    "compilerOptions": {
        "target":"es5",
        "module":"commonjs",
        "moduleResolution":"node",
        "removeComments": true,
        "noImplicitAny": true,
        "outDir": "./js",
        "typeRoots": [
            "./node_modules/@types"
        ],
        "types": [
            "socket.io-client"
        ]
    },
    "include": [
        "./ts/*"
    ]
}
